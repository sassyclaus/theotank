{
  "name": "theotank",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "env:up": "docker compose up -d",
    "env:down": "docker compose down",
    "db:migrate": "bun run packages/rds/src/kysely-migrate.ts",
    "db:migrate:create": "bun run --cwd packages/rds db:migrate:create",
    "db:generate-types": "bun run --cwd packages/rds db:generate-types",
    "db:seed": "bun run packages/rds/src/seed.ts",
    "db:seed:update": "bun run packages/rds/src/seed-update.ts",
    "api:dev": "bun run --watch packages/api/src/index.ts",
    "web:dev": "bun run --cwd packages/web dev",
    "site:dev": "bun run --cwd packages/site dev",
    "site:build": "bun run --cwd packages/site build",
    "dev": "docker compose up -d && bun run --watch packages/api/src/index.ts & bun run --cwd packages/web dev & wait",
    "worker:rebuild": "docker compose up -d --build worker",
    "worker:logs": "docker compose logs -f worker",
    "cron:dev": "bun run --watch packages/cron/src/index.ts"
  }
}
