{
  "name": "theotank",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "env:up": "docker compose up -d",
    "env:down": "docker compose down",
    "db:generate": "bun run --cwd packages/rds db:generate",
    "db:migrate": "bun run --cwd packages/rds db:migrate",
    "db:push": "bun run --cwd packages/rds db:push",
    "db:studio": "bun run --cwd packages/rds db:studio",
    "db:migrate:run": "bun run packages/rds/src/migrate.ts",
    "db:seed": "bun run packages/rds/src/seed.ts",
    "db:seed:update": "bun run packages/rds/src/seed-update.ts",
    "api:dev": "bun run --watch packages/api/src/index.ts",
    "web:dev": "bun run --cwd packages/web dev",
    "dev": "docker compose up -d && bun run --watch packages/api/src/index.ts & bun run --cwd packages/web dev & bun run --cwd packages/rds db:studio & wait"
  }
}
