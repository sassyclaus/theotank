---
import ToolCard from "../cards/ToolCard.astro";
import { tools } from "../../data/tools";
---

<section class="py-20 md:py-28">
  <div class="mx-auto max-w-[800px] px-6">
    <h2 class="text-center font-serif text-2xl font-semibold text-text-primary md:text-3xl">
      What will you do with 2,000 years of theology<br class="hidden md:block" />
      at your fingertips?
    </h2>
  </div>

  <div class="mx-auto mt-12 max-w-5xl space-y-6 px-6">
    {tools.map((tool) => (
      <ToolCard
        title={tool.title}
        slug={tool.slug}
        description={tool.description}
        sampleLabel={tool.sampleLabel}
        sampleContent={tool.sampleContent}
        sampleAttribution={tool.sampleAttribution}
      />
    ))}
  </div>
</section>
