{
  "name": "@theotank/rds",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:migrate": "bun run src/kysely-migrate.ts",
    "db:migrate:create": "bun run src/create-migration.ts",
    "db:generate-types": "kysely-codegen --out-file ./src/kysely-types.ts --dialect postgres"
  },
  "dependencies": {
    "kysely": "^0.28.11",
    "kysely-postgres-js": "^3.0.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "kysely-codegen": "^0.20.0",
    "pg": "^8.20.0",
    "typescript": "~5.7.0"
  }
}
