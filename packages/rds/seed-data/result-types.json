[
  {
    "kind": "ask",
    "version": 1,
    "description": "Initial Ask result type — panel perspectives with synthesized conclusion",
    "contentSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["tool", "summary", "perspectives"],
      "properties": {
        "tool": { "const": "ask" },
        "summary": { "type": "string" },
        "perspectives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["theologian", "perspective"],
            "properties": {
              "theologian": { "$ref": "#/$defs/resultTheologian" },
              "perspective": { "type": "string" }
            }
          }
        }
      },
      "$defs": {
        "resultTheologian": {
          "type": "object",
          "required": ["name", "initials", "dates", "tradition", "color"],
          "properties": {
            "name": { "type": "string" },
            "initials": { "type": "string" },
            "dates": { "type": "string" },
            "tradition": { "type": "string" },
            "color": { "type": "string" }
          }
        }
      }
    },
    "previewSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["type", "conclusion"],
      "properties": {
        "type": { "const": "ask" },
        "conclusion": { "type": "string" }
      }
    },
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["question"],
      "properties": {
        "question": { "type": "string" }
      }
    },
    "isActive": true
  },
  {
    "kind": "poll",
    "version": 1,
    "description": "Poll result type — raw theologian selections with LLM-generated summary",
    "contentSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["question", "optionLabels", "summary", "theologianSelections", "errors"],
      "properties": {
        "question": { "type": "string" },
        "optionLabels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": { "type": "string" },
        "theologianSelections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["theologian", "selection", "justification"],
            "properties": {
              "theologian": { "$ref": "#/$defs/pollTheologian" },
              "selection": { "type": "string" },
              "justification": { "type": "string" }
            }
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["theologianName", "error"],
            "properties": {
              "theologianName": { "type": "string" },
              "error": { "type": "string" }
            }
          }
        }
      },
      "$defs": {
        "pollTheologian": {
          "type": "object",
          "required": ["name", "initials", "dates", "tradition", "color"],
          "properties": {
            "name": { "type": "string" },
            "initials": { "type": "string" },
            "dates": { "type": "string" },
            "tradition": { "type": "string" },
            "color": { "type": "string" },
            "born": { "type": ["integer", "null"] }
          }
        }
      }
    },
    "previewSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["type", "bars"],
      "properties": {
        "type": { "const": "poll" },
        "bars": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "percentage"],
            "properties": {
              "label": { "type": "string" },
              "percentage": { "type": "number" }
            }
          }
        }
      }
    },
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["question", "options"],
      "properties": {
        "question": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "isActive": true
  },
  {
    "kind": "review",
    "version": 1,
    "description": "Initial Review result type — theologian assessments with grades and feedback",
    "contentSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["tool", "grade", "summary", "reactions"],
      "properties": {
        "tool": { "const": "review" },
        "grade": { "type": "string" },
        "summary": { "type": "string" },
        "reactions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["theologian", "grade", "assessment", "strengths", "weaknesses"],
            "properties": {
              "theologian": { "$ref": "#/$defs/resultTheologian" },
              "grade": { "type": "string" },
              "assessment": { "type": "string" },
              "strengths": {
                "type": "array",
                "items": { "type": "string" }
              },
              "weaknesses": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      },
      "$defs": {
        "resultTheologian": {
          "type": "object",
          "required": ["name", "initials", "dates", "tradition", "color"],
          "properties": {
            "name": { "type": "string" },
            "initials": { "type": "string" },
            "dates": { "type": "string" },
            "tradition": { "type": "string" },
            "color": { "type": "string" }
          }
        }
      }
    },
    "previewSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["type", "grade"],
      "properties": {
        "type": { "const": "review" },
        "grade": { "type": "string" }
      }
    },
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "documentKey": { "type": "string" },
        "documentText": { "type": "string" }
      }
    },
    "isActive": true
  },
  {
    "kind": "research",
    "version": 1,
    "description": "Research result type — RAG pipeline with claim verification and citation-grounded synthesis",
    "contentSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["tool", "question", "theologianName", "theologianSlug", "responseText", "citations", "metadata"],
      "properties": {
        "tool": { "const": "research" },
        "question": { "type": "string" },
        "theologianName": { "type": "string" },
        "theologianSlug": { "type": "string" },
        "responseText": { "type": "string" },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "marker", "claimText", "claimType", "confidence", "sources"],
            "properties": {
              "id": { "type": "string" },
              "marker": { "type": "string" },
              "claimText": { "type": "string" },
              "claimType": {
                "type": "string",
                "enum": ["paraphrase", "quote", "inference"]
              },
              "confidence": {
                "type": "string",
                "enum": ["HIGH", "MEDIUM", "LOW"]
              },
              "sources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["workTitle", "canonicalRef", "originalText", "translation"],
                  "properties": {
                    "workTitle": { "type": "string" },
                    "canonicalRef": { "type": "string" },
                    "originalText": { "type": "string" },
                    "translation": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "anglesProcessed": { "type": "integer" },
            "totalClaims": { "type": "integer" },
            "evidenceItemsUsed": { "type": "integer" }
          }
        }
      }
    },
    "previewSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["type", "citedSourcesCount"],
      "properties": {
        "type": { "const": "research" },
        "citedSourcesCount": { "type": "integer" }
      }
    },
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["question"],
      "properties": {
        "question": { "type": "string" }
      }
    },
    "isActive": true
  }
]
